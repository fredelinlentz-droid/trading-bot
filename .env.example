# ══════════════════════════════════════════════
# TRADING BOT — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ══════════════════════════════════════════════

# Clé API pour sécuriser les endpoints
API_SECRET=change-this-secret-key-now

# Telegram (optionnel — pour les notifications)
# Créer un bot via @BotFather sur Telegram
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Alpha Vantage (optionnel — données premium)
ALPHA_VANTAGE_KEY=

# Base de données (sqlite par défaut)
DATABASE_URL=sqlite:///trading.db

# Port du serveur API
PORT=8000
